# pnpm 配置
# miniprogram-ci 内部使用 @babel/preset-env 编译小程序代码，
# 但其依赖 @babel/types 在 pnpm 严格隔离结构下无法被找到。
# 用 public-hoist-pattern 把 babel 相关包提升到顶层 node_modules，
# 使 miniprogram-ci 的 worker 能正确 require 到 @babel/types。
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=miniprogram-ci
shamefully-hoist=true
